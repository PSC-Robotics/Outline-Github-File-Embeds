# Global fallback token (works if your single user account/bot has access to everything needed)
GITHUB_TOKEN=ghp_your_token_here

# Alternatively, or additionally, you can specify tokens per organization:
# format: GITHUB_TOKEN_ORGANIZATIONNAME=ghp_...
# Example for github.com/PSC-Robotics:
# GITHUB_TOKEN_PSC_ROBOTICS=ghp_...

# URL of your Outline instance (for CORS)
OUTLINE_URL=https://outline.your-domain.com

# Port the proxy runs on
PORT=3456

# How long to cache fetched files in seconds
CACHE_TTL=60
