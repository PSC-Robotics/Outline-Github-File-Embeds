# === AUTHENTICATION (CHOOSE ONE METHOD) ===

# METHOD 1: GitHub App (Recommended for Organizations)
# Create a GitHub App in your Org Settings -> Developer Settings
# Grant "Contents: Read-only" permission. Install it on your org.
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_INSTALLATION_ID=98765432

# METHOD 2: Personal Access Token (Fallback/Legacy)
# A fine-grained PAT belonging to a user account.
GITHUB_TOKEN=

# === GENERAL CONFIG ===
OUTLINE_URL=https://outline.your-domain.com
PORT=3456
CACHE_TTL=60
